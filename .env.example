# Copy to .env — consumed by docker-compose and the backend (KMQ_ prefix).

# --- database (docker-compose) ---
KMQ_DB_USER=kingsmarque
KMQ_DB_PASSWORD=change-me
KMQ_DB_NAME=kingsmarque

# --- backend core ---
# KMQ_DATABASE_URL is derived in docker-compose; set explicitly for bare-metal runs.
KMQ_SECRET_KEY=generate-a-long-random-value
KMQ_ENVIRONMENT=development

# --- document storage (Part 5) ---
KMQ_STORAGE_LOCAL_ROOT=/data/documents
KMQ_UPLOAD_MAX_BYTES=52428800
KMQ_ZIP_MAX_ENTRIES=200
KMQ_ZIP_MAX_TOTAL_BYTES=524288000

# --- OCR pipeline (Part 6) ---
KMQ_OCR_AUTO=true
KMQ_OCR_ENGINES=paddleocr,doctr,tesseract
KMQ_OCR_DPI=220
KMQ_OCR_TESSERACT_LANGS=eng
KMQ_OCR_PADDLE_LANG=en

# --- local AI (Part 8): self-hosted only, no API keys anywhere ---
KMQ_AI_PROVIDER=ollama            # ollama | vllm
# KMQ_AI_BASE_URL is set to http://ollama:11434 by docker-compose;
# for bare-metal Ollama use http://localhost:11434,
# for vLLM point at its OpenAI-compatible server, e.g. http://vllm:8000
KMQ_AI_DEFAULT_MODEL=qwen2.5:7b
KMQ_AI_TIMEOUT_S=120
KMQ_AI_MAX_TOKENS=2048
KMQ_AI_TEMPERATURE=0.1

# --- vector database & RAG retrieval (Part 9) ---
KMQ_EMBED_MODEL=bge-m3          # multilingual embeddings (pull via ollama)
KMQ_EMBED_DIM=1024              # fixed per deployment; changing => re-migrate + re-embed
KMQ_EMBED_AUTO=true             # chain chunk+embed after OCR completes
KMQ_CHUNK_SIZE=1200
KMQ_CHUNK_OVERLAP=150

# --- translation (Part 12) ---
KMQ_TRANSLATE_ENGINES=indictrans2,llm   # IndicTrans2 optional: pip install .[translate-indic]
# Seed the legal-terminology glossary once per deployment:
#   python -m app.cli seed-glossary

# --- security (Part 17) ---
KMQ_GLOBAL_RATE_LIMIT_PER_MINUTE=300   # per client IP, all endpoints
KMQ_MAX_BODY_BYTES=62914560            # 60 MB request cap
KMQ_HSTS_ENABLED=false                 # set true ONLY once TLS is live (Part 19)
KMQ_DOCS_ENABLED=true                  # set false in production
# Optional at-rest document encryption (Fernet). Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing this key makes encrypted documents unrecoverable.
KMQ_STORAGE_ENCRYPTION_KEY=
