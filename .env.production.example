# Kingsmarque — PRODUCTION environment (Part 19).
#   cp .env.production.example .env.production   # then fill EVERY secret
# Never commit .env.production. Generate secrets exactly as commented.

# ---------- deployment ----------
KMQ_ENV=prod                          # disables OpenAPI docs, prod error modes
KMQ_DOMAIN=due-diligence.yourfirm.in  # public DNS name (or LAN hostname)
KMQ_FRONTEND_ORIGIN=https://due-diligence.yourfirm.in

# ---------- database (compose-internal) ----------
KMQ_DB_USER=kmq
KMQ_DB_NAME=kingsmarque
# python3 -c "import secrets; print(secrets.token_urlsafe(24))"
KMQ_DB_PASSWORD=

# ---------- auth secrets ----------
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
KMQ_SECRET_KEY=

# ---------- security (Part 17) ----------
KMQ_HSTS_ENABLED=true                 # TLS terminates at the proxy: enable
KMQ_DOCS_ENABLED=false
KMQ_GLOBAL_RATE_LIMIT_PER_MINUTE=300
KMQ_MAX_BODY_BYTES=62914560           # keep <= proxy client_max_body_size (64m)
# At-rest document encryption (STRONGLY recommended for legal documents):
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Losing this key makes encrypted documents unrecoverable — store it in a
# password manager AND with your offline backups.
KMQ_STORAGE_ENCRYPTION_KEY=

# ---------- AI ----------
KMQ_AI_DEFAULT_MODEL=qwen2.5:7b
KMQ_EMBED_MODEL=bge-m3
KMQ_EMBED_DIM=1024

# ---------- OCR / translation ----------
KMQ_OCR_ENGINES=tesseract             # add paddleocr,doctr if extras installed
KMQ_TRANSLATE_ENGINES=indictrans2,llm

# ---------- email (verification/reset delivery) ----------
KMQ_EMAIL_BACKEND=smtp                # console (logs) | smtp
KMQ_SMTP_HOST=
KMQ_SMTP_PORT=587
KMQ_SMTP_USER=
KMQ_SMTP_PASSWORD=
KMQ_EMAIL_FROM=noreply@yourfirm.in

# ---------- backups ----------
KMQ_BACKUP_RETENTION_DAYS=14
